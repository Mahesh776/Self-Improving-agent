# LLM Provider API Keys
# Get OpenRouter key at: https://openrouter.ai/keys (many free models available!)
OPENROUTER_API_KEY=your_openrouter_key_here
# Get Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Model Configuration
# Free OpenRouter models: google/gemini-2.0-flash-exp:free, meta-llama/llama-3.3-70b-instruct:free
# Paid OpenRouter models: openai/gpt-4o-mini
# Gemini models: gemini/gemini-2.0-flash, gemini/gemini-1.5-flash
SCOUT_MODEL=google/gemini-2.0-flash-exp:free
FORGE_MODEL=google/gemini-2.0-flash-exp:free

# Backend Configuration
LITELLM_MASTER_KEY=your_master_key_here
BACKEND_PORT=8080
TOOL_RUNTIME_PORT=8090
