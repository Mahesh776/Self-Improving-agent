# LLM Provider API Keys
# Get OpenRouter key at: https://openrouter.ai/keys (many free models!)
OPENROUTER_API_KEY=your_openrouter_key_here
# Get Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Model Configuration (use free models from OpenRouter)
SCOUT_MODEL=qwen/qwen3.5:free
FORGE_MODEL=qwen/qwen3.5:free

# Backend Configuration
LITELLM_MASTER_KEY=your_master_key_here
BACKEND_PORT=8080
TOOL_RUNTIME_PORT=8090
