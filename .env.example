# LLM Provider API Keys
# Get OpenRouter key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Get Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Model Configuration
# OpenRouter models: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
# Gemini models: gemini/gemini-2.0-flash, gemini/gemini-1.5-pro
SCOUT_MODEL=openai/gpt-4o-mini
FORGE_MODEL=openai/gpt-4o-mini

# Backend Configuration
LITELLM_MASTER_KEY=your_master_key_here
BACKEND_PORT=8080
TOOL_RUNTIME_PORT=8090
